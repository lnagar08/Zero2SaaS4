generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// ── SaaS Core Tables ──
model Organization {
  id               String   @id @default(uuid())
  name             String
  slug             String   @unique
  stripeCustomerId String?  @unique
  brandColor       String   @default("#1e3a5f")
  brandTagline     String   @default("")
  brandLogoText    String   @default("")
  brandLogoUrl     String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  users            User[]
  invitations      Invitation[]
  subscription     Subscription?
  matterFlows      MatterFlow[]
  flowStages       FlowStage[]
  flowSteps        FlowStep[]
  matters          Matter[]
  matterStageProgress MatterStageProgress[]
  matterStepProgress  MatterStepProgress[]
  flowControls     FlowControl[]
}

model User {
  id            String   @id @default(uuid())
  orgId         String
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  email         String   @unique
  name          String
  passwordHash  String?
  role          Role     @default(MEMBER)
  parentId      String?  // For hierarchical user structures (e.g., sub-users under a main account)
  permissions   Json?           @default("{}")
  emailVerified DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  status        String   @default("active")
  accounts      Account[]
  sessions      Session[]
  @@index([orgId])
}

enum Role { 
  OWNER 
  ADMIN
  MEMBER 
  ATTORNEY
  STAFF
}

model Plan {
  id              String   @id @default(uuid())
  name            String   // e.g., "Basic", "Pro"
  stripeProductId String?
  stripePriceId   String   @unique
  priceCents      Int      // Price in cents for easy reference
  billingInterval String @default("monthly")
  allowMatter     Int      // Limit for "Matters"
  allowTeamUser   Int      // Limit for Team Members
  createdAt       DateTime @default(now())
}

model Subscription {
  id                   String   @id @default(uuid())
  orgId                String   @unique
  org                  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String   @unique
  stripePriceId        String
  stripeCustomerId     String   @unique // Essential for the Portal session
  status               SubscriptionStatus
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  trialEnd             DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

enum SubscriptionStatus { 
  TRIALING 
  ACTIVE 
  PAST_DUE 
  CANCELED 
  UNPAID 
}

model Invitation {
  id        String   @id @default(uuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  email     String
  role      Role     @default(MEMBER)
  permissions   Json?           @default("{}")
  token     String   @unique @default(uuid())
  expiresAt DateTime
  createdAt DateTime @default(now())
  status    String   @default("pending") // pending, accepted, expired
  @@index([orgId])
}

model Account {
  id                String @id @default(uuid())
  userId            String
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
}

model VerificationToken {
  identifier String
  token      String @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ══════════════════════════════════════════
// PRODUCT TABLES — MatterGuardian
// ══════════════════════════════════════════
model MatterFlow {
  id          String   @id @default(uuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isDefault   Boolean  @default(false)
  isPublic    Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  stages      FlowStage[]
  matters     Matter[]
  @@index([orgId])
}

model FlowStage {
  id                  String   @id @default(uuid())
  orgId               String
  org                 Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  matterFlowId        String
  matterFlow          MatterFlow @relation(fields: [matterFlowId], references: [id], onDelete: Cascade)
  name                String
  sortOrder           Int      @default(0)
  defaultDurationDays Int?
  createdAt           DateTime @default(now())
  steps               FlowStep[]
  @@index([orgId])
  @@index([matterFlowId])
}

model FlowStep {
  id            String   @id @default(uuid())
  orgId         String
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  stageId       String
  stage         FlowStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  sortOrder     Int      @default(0)
  dueDaysOffset Int?
  isRequired    Boolean  @default(true)
  createdAt     DateTime @default(now())
  @@index([orgId])
  @@index([stageId])
}

model Matter {
  id              String   @id @default(uuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  matterFlowId    String
  matterFlow      MatterFlow @relation(fields: [matterFlowId], references: [id], onDelete: Cascade)
  referenceNumber String?
  name            String
  clientName      String
  clientCompany   String?
  clientEmail     String?
  description     String?
  status          String   @default("active")
  assignedUserId  String?
  currentStageId  String?
  startDate       DateTime @default(now())
  targetEndDate   DateTime?
  completedDate   DateTime?
  amountPaid      Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  stageProgress   MatterStageProgress[]
  @@index([orgId])
  @@index([assignedUserId])
  @@index([matterFlowId])
}

model MatterStageProgress {
  id          String    @id @default(uuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  matterId    String
  matter      Matter    @relation(fields: [matterId], references: [id], onDelete: Cascade)
  stageId     String
  stageName   String
  sortOrder   Int       @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  steps       MatterStepProgress[]
  @@index([orgId])
  @@index([matterId])
}

model MatterStepProgress {
  id                    String    @id @default(uuid())
  orgId                 String
  org                   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  matterStageProgressId String
  matterStageProgress   MatterStageProgress @relation(fields: [matterStageProgressId], references: [id], onDelete: Cascade)
  stepId                String
  stepName              String
  sortOrder             Int       @default(0)
  isRequired            Boolean   @default(true)
  isCompleted           Boolean   @default(false)
  completedAt           DateTime?
  dueDate               DateTime?
  manualDueDate         DateTime?
  notes                 String?
  withClient            Boolean   @default(false)
  withClientSince       DateTime?
  @@index([orgId])
  @@index([matterStageProgressId])
}

model FlowControl {
  id                       String   @id @default(uuid())
  orgId                    String   @unique
  org                      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  dueSoonWindowDays        Int      @default(2)
  stageRiskThresholdDays   Int      @default(14)
  graceWindowDays          Int      @default(2)
  breakdownOnPastDue       Boolean  @default(true)
  breakdownOnInactivity    Boolean  @default(true)
  breakdownInactivityDays  Int      @default(14)
  breakdownOnStepOverdue   Boolean  @default(true)
  breakdownStepOverdueDays Int      @default(21)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}
